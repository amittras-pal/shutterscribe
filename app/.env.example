# ShutterScribe — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Shutterstock FTPS Credentials ──────────────────────────────────────────
# Your Shutterstock contributor email address or username
SHUTTERSTOCK_FTP_USER=your_contributor_email@example.com

# Your Shutterstock contributor account password
SHUTTERSTOCK_FTP_PASSWORD=your_shutterstock_password

# ── FTPS Connection (optional — defaults shown) ─────────────────────────────
# Shutterstock FTPS server (do not change unless instructed)
SHUTTERSTOCK_FTP_HOST=ftps.shutterstock.com

# FTPS port (Explicit TLS, port 21)
SHUTTERSTOCK_FTP_PORT=21

# ── Parallel Upload (optional) ───────────────────────────────────────────────
# Number of simultaneous FTPS connections for parallel uploads.
# 1 = serial (safe default). 3 = recommended maximum for Shutterstock.
# Each worker opens its own TLS session reused across its entire file batch.
# Do NOT exceed 5 — risk of server rejection (421 Too many connections).
SHUTTERSTOCK_FTP_PARALLEL=1
